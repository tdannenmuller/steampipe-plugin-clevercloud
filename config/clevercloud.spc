connection "clevercloud" {
  plugin = "tdannenmuller/clevercloud"

  # API token for Clever Cloud authentication.
  token = "YOUR_API_TOKEN"

  # Organization ID for your Clever Cloud account.
  organization_id = "YOUR_ORG_ID"

  # API endpoint URL for Clever Cloud.
  api_endpoint = "https://api-bridge.clever-cloud.com"
}